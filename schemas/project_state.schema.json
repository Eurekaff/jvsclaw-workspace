{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProjectState",
  "description": "全局项目状态，贯穿整个工作流生命周期",
  "type": "object",
  "required": ["project_name", "raw_brief", "current_stage", "artifacts_index"],
  "properties": {
    "project_name": {
      "type": "string",
      "description": "项目名称"
    },
    "raw_brief": {
      "type": "string",
      "description": "用户原始输入的项目简述"
    },
    "current_stage": {
      "type": "string",
      "enum": [
        "idea_input",
        "problem_definition",
        "mvp_scope",
        "context_pack",
        "mainline_build",
        "quality_correction",
        "productization",
        "retrospective",
        "completed"
      ],
      "description": "当前所处阶段"
    },
    "approved_scope": {
      "type": "object",
      "description": "已确认的范围定义",
      "properties": {
        "must_have": {"type": "array", "items": {"type": "string"}},
        "nice_to_have": {"type": "array", "items": {"type": "string"}},
        "out_of_scope": {"type": "array", "items": {"type": "string"}}
      }
    },
    "tech_stack": {
      "type": "array",
      "items": {"type": "string"},
      "description": "技术栈选择"
    },
    "constraints": {
      "type": "array",
      "items": {"type": "string"},
      "description": "项目约束条件"
    },
    "artifacts_index": {
      "type": "object",
      "description": "各阶段产出物索引",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "path": {"type": "string"},
          "created_at": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "approved", "revised"]}
        }
      }
    },
    "pending_questions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "待用户确认的问题"
    },
    "validation_results": {
      "type": "object",
      "description": "验证结果",
      "additionalProperties": true
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "下一步行动建议"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {"type": "string"},
        "updated_at": {"type": "string"},
        "version": {"type": "string"}
      }
    }
  }
}
