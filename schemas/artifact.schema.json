{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArtifactSchema",
  "description": "通用产出物 schema",
  "type": "object",
  "required": ["stage", "type", "content"],
  "properties": {
    "stage": {
      "type": "string",
      "description": "所属阶段"
    },
    "type": {
      "type": "string",
      "enum": ["markdown", "json", "code", "config"],
      "description": "产出物类型"
    },
    "filename": {
      "type": "string",
      "description": "文件名"
    },
    "content": {
      "type": "string",
      "description": "文件内容"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {"type": "string"},
        "word_count": {"type": "number"},
        "checksum": {"type": "string"}
      }
    }
  }
}
